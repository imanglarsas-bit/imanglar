# Copia este archivo como .env en producción (Vercel u otro host)
# NUNCA subas el archivo .env al repositorio

# Resend — envío automático de correos con adjuntos
# Obtén tu clave en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Inversiones Manglar <notificaciones@imanglar.com>"
EMAIL_TO_EVCAR=evcarelectricol@gmail.com
EMAIL_TO_LEGAL=consultasjuridicasgje@gmail.com

# MercadoPago — checkout de pago en línea
# Obtén tu Access Token en https://www.mercadopago.com.co/developers/panel
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# URL pública del sitio — usada para las URLs de retorno de MercadoPago
NEXT_PUBLIC_SITE_URL=https://tudominio.com

# AWS S3 — Mucuba Hotel & Glamping
AWS_REGION=us-east-1
AWS_S3_BUCKET=tu-bucket
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_PUBLIC_BASE_URL=https://tu-bucket.s3.us-east-1.amazonaws.com

# Admin Mucuba — autenticación del panel
MUCUBA_ADMIN_USER=admin
MUCUBA_ADMIN_PASSWORD=pon-una-clave-larga
MUCUBA_ADMIN_TOKEN=pon-un-token-largo-aleatorio
