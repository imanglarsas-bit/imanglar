# Copia este archivo como .env en producción (Vercel u otro host)
# NUNCA subas el archivo .env al repositorio

# Resend — envío automático de correos con adjuntos
# Obtén tu clave en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# MercadoPago — checkout de pago en línea
# Obtén tu Access Token en https://www.mercadopago.com.co/developers/panel
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# URL pública del sitio — usada para las URLs de retorno de MercadoPago
NEXT_PUBLIC_SITE_URL=https://tudominio.com
